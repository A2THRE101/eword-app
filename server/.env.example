# Local SQLite database file. For production, replace this with a managed database URL.
DATABASE_URL="file:./dev.db"

# Generate a long random value before running outside local development.
JWT_SECRET="replace-with-at-least-32-random-characters"

# API port.
PORT=3000

# For local static preview. In production, set your frontend origin instead of *.
FRONTEND_ORIGIN="*"

# Optional demo seed values used by npm run seed.
DEMO_LOGIN="murad"
DEMO_PASSWORD="1234"
DEMO_NAME="Мурад"
